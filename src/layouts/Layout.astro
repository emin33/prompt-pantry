---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SigmondWidget from "../components/SigmondWidget";

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  ogImage?: string;
}

const {
  title,
  description = "Recipes for real kitchens.",
  ogType = "website",
  ogImage,
} = Astro.props;

const siteTitle = "Prompt Pantry";
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
const ogImageUrl = ogImage
  ? `https://promptpantry.org${ogImage}`
  : "https://promptpantry.org/images/og-image.png";

// Agent URL injected at build time. In dev, point this at your ngrok URL
// (or localhost if you've proxied it). Example:
//   PUBLIC_SIGMOND_AGENT_URL=https://abcd1234.ngrok-free.app
const agentUrl = import.meta.env.PUBLIC_SIGMOND_AGENT_URL ?? "";

// Build-time diagnostic: dumps everything relevant so we can tell at a glance
// whether Cloudflare/Astro actually read the env var during the build.
// View page source, search "sigmond-build-diag". Remove once confirmed working.
const _buildDiag = {
  agentUrl,
  present: Boolean(agentUrl),
  rawEnvType: typeof import.meta.env.PUBLIC_SIGMOND_AGENT_URL,
  allPublicKeys: Object.keys(import.meta.env)
    .filter((k) => k.startsWith("PUBLIC_"))
    .join(","),
  buildTime: new Date().toISOString(),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{fullTitle}</title>
    <meta name="sigmond-build-diag" content={JSON.stringify(_buildDiag)} />
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=DM+Serif+Display&display=swap"
      rel="stylesheet"
    />
    <!-- SignalWire browser SDK (UMD — exposes window.SignalWire). Served
         locally from public/ rather than a CDN so we get a known-good
         version and no external runtime dependency. -->
    <script src="/signalwire.js" is:inline></script>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Paper texture SVG filter -->
    <svg class="hidden" aria-hidden="true">
      <filter id="paper-texture">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="5" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
    </svg>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <!-- Sigmond voice assistant. Persists across client-side navigations. -->
    <SigmondWidget client:load transition:persist="sigmond" agentUrl={agentUrl} />
  </body>
</html>
