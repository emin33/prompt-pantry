---
import { getCollection } from "astro:content";

interface Props {
  slug: string;
}

const { slug } = Astro.props;

const techniques = await getCollection("techniques");
const technique = techniques.find((t) => t.data.slug === slug);
---

{technique ? (
  <a
    href={`/techniques/${technique.data.slug}`}
    class="technique-callout group flex items-start gap-3 my-4 p-3 rounded-lg bg-sage-light/50 border border-sage/20 hover:border-sage/40 transition-colors no-underline"
  >
    <svg class="w-5 h-5 mt-0.5 text-sage flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
    </svg>
    <div>
      <span class="text-sm font-medium text-sage-dark group-hover:text-sage transition-colors">
        Technique: {technique.data.title}
      </span>
      <span class="block text-xs text-warm-gray mt-0.5">
        {technique.data.description}
      </span>
    </div>
  </a>
) : (
  <span class="text-xs text-warm-gray italic">Technique guide: {slug}</span>
)}
