---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/recipes", label: "Recipes" },
  { href: "/techniques", label: "Techniques" },
  { href: "/generate", label: "Generate" },
  { href: "/about", label: "About" },
];
---

<header class="border-b border-warm-gray/15 bg-cream/80 backdrop-blur-sm sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="no-underline">
      <img src="/images/logo.png" alt="Prompt Pantry" class="h-14" />
    </a>
    <ul class="flex items-center gap-6 text-sm font-medium">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "no-underline transition-colors",
              currentPath.startsWith(href)
                ? "text-terracotta"
                : "text-muted hover:text-charcoal",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <button
          type="button"
          onclick="window.__sigmondWake?.()"
          class="inline-flex items-center gap-1.5 text-muted hover:text-charcoal transition-colors"
          title="Talk to Sigmond"
          aria-label="Talk to Sigmond"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-sage animate-pulse"></span>
          Sigmond
        </button>
      </li>
    </ul>
  </nav>
</header>
