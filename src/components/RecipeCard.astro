---
interface Props {
  title: string;
  slug: string;
  description: string;
  cuisine: string;
  difficulty: string;
  totalTime: number;
  category: string;
  image?: string;
}

const { title, slug, description, cuisine, difficulty, totalTime, category, image } = Astro.props;

const difficultyLevels: Record<string, number> = {
  Easy: 1,
  Medium: 2,
  Hard: 3,
  Project: 3,
};

const flames = difficultyLevels[difficulty] || 1;

// Cuisine emoji
const cuisineEmoji: Record<string, string> = {
  Indian: "\u{1F1EE}\u{1F1F3}",
  Japanese: "\u{1F1EF}\u{1F1F5}",
  Italian: "\u{1F1EE}\u{1F1F9}",
  French: "\u{1F1EB}\u{1F1F7}",
  Mexican: "\u{1F1F2}\u{1F1FD}",
  Thai: "\u{1F1F9}\u{1F1ED}",
  Korean: "\u{1F1F0}\u{1F1F7}",
  "Chinese-American": "\u{1F1FA}\u{1F1F8}",
  American: "\u{1F1FA}\u{1F1F8}",
};

// Category emoji for hero area
const categoryEmoji: Record<string, string> = {
  Pasta: "\u{1F35D}",
  Meat: "\u{1F969}",
  Seafood: "\u{1F990}",
  Vegetarian: "\u{1F96C}",
  Soup: "\u{1F372}",
  Dessert: "\u{1F370}",
  Breakfast: "\u{1F373}",
  Sides: "\u{1F957}",
  Sauces: "\u{1F9C8}",
  Bread: "\u{1F35E}",
};

const emoji = cuisineEmoji[cuisine] || "";
const heroEmoji = categoryEmoji[category] || "\u{1F37D}\u{FE0F}";

// Category color accents
const categoryColors: Record<string, string> = {
  Pasta: "bg-golden-light",
  Meat: "bg-terracotta/8",
  Seafood: "bg-sage-light/50",
  Vegetarian: "bg-sage-light",
  Soup: "bg-golden-light/50",
  Dessert: "bg-terracotta/5",
  Breakfast: "bg-golden-light",
  Sides: "bg-sage-light/30",
  Sauces: "bg-terracotta/5",
  Bread: "bg-golden-light/50",
};

const accent = categoryColors[category] || "bg-cream";
---

<a
  href={`/recipes/${slug}`}
  class="group block bg-warm-white rounded-xl border border-warm-gray/10 hover:border-warm-gray/25 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden no-underline"
>
  {/* Hero area */}
  {image ? (
    <div class="aspect-[16/10] overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    </div>
  ) : (
    <div class={`${accent} flex items-center justify-center py-6`}>
      <span class="text-5xl opacity-80 group-hover:scale-110 transition-transform duration-300">{heroEmoji}</span>
    </div>
  )}

  <div class="p-5">
    <h3 class="font-display text-xl text-charcoal group-hover:text-terracotta transition-colors leading-snug mb-2">
      {title}
    </h3>

    <p class="text-sm text-warm-gray line-clamp-2 mb-4 leading-relaxed">{description}</p>

    <div class="flex items-center justify-between text-xs text-muted">
      <div class="flex items-center gap-3">
        <span class="px-2 py-0.5 rounded-full bg-terracotta/8 text-terracotta font-medium">
          {emoji && <span class="mr-1">{emoji}</span>}{cuisine}
        </span>
        <span class="flex gap-0.5 cursor-help" title={`Difficulty: ${difficulty}`}>
          {Array.from({ length: 3 }).map((_, i) => (
            <svg
              class={`w-3 h-3 ${i < flames ? "text-golden" : "text-warm-gray/20"}`}
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M12 2c-1 4-4 6-4 10a4 4 0 008 0c0-4-3-6-4-10z" />
            </svg>
          ))}
        </span>
      </div>
      <div class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <polyline points="12,6 12,12 16,14" />
        </svg>
        {totalTime} min
      </div>
    </div>
  </div>
</a>
