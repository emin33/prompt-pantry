---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import RecipeCard from "../components/RecipeCard.astro";

const recipes = await getCollection("recipes", ({ data }) => data.published && data.source !== "community" && !data.variantOf);
const communityRecipes = await getCollection("recipes", ({ data }) => data.published && data.source === "community" && !data.variantOf);

// Sort by publishedDate descending
const sorted = recipes.sort(
  (a, b) => b.data.publishedDate.localeCompare(a.data.publishedDate)
);
const communitySorted = communityRecipes.sort(
  (a, b) => b.data.publishedDate.localeCompare(a.data.publishedDate)
).slice(0, 6);

const featured = sorted.find((r) => r.data.slug === "jamaican-jerk-chicken") || sorted[0];
const recent = sorted.filter((r) => r.data.slug !== featured.data.slug).slice(0, 6);
---

<Layout title="Prompt Pantry">
  {/* Hero */}
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 pb-8 text-center">
    <img src="/images/logo.png" alt="Prompt Pantry" class="h-32 md:h-44 mx-auto mb-2" />
    <p class="text-lg text-warm-gray italic font-light">Yummy! Yummy!</p>
  </section>

  {/* Featured recipe */}
  {featured && (
    <section class="max-w-4xl mx-auto px-4 sm:px-6 mb-16">
      <a
        href={`/recipes/${featured.data.slug}`}
        class="group block bg-warm-white rounded-2xl border border-warm-gray/10 hover:border-warm-gray/25 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden no-underline"
      >
        {featured.data.image && (
          <div class="aspect-[21/9] overflow-hidden">
            <img
              src={featured.data.image}
              alt={featured.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
        )}
        <div class="p-8 md:p-10">
          <span class="inline-block text-xs font-semibold text-warm-white bg-terracotta px-3 py-1 rounded-full tracking-wide uppercase mb-4">
            Featured Recipe
          </span>
          <h2 class="font-display text-3xl md:text-4xl text-charcoal group-hover:text-terracotta transition-colors mb-3">
            {featured.data.title}
          </h2>
          <p class="text-warm-gray mb-5 max-w-2xl text-lg leading-relaxed">
            {featured.data.description}
          </p>
          <div class="flex items-center gap-4 text-sm text-muted">
            <span class="px-3 py-1 rounded-full bg-terracotta/8 text-terracotta font-medium">
              {featured.data.cuisine}
            </span>
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12,6 12,12 16,14" />
              </svg>
              {featured.data.totalTime} min
            </span>
            <span>{featured.data.difficulty}</span>
          </div>
        </div>
      </a>
    </section>
  )}

  {/* Divider */}
  <div class="flex justify-center mb-16">
    <div class="w-48 h-1 rounded-full" style="background: linear-gradient(135deg, #C75B3F 50%, #7A9E7E 50%);" />
  </div>

  {/* Recent recipes */}
  {recent.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-2xl text-charcoal">Recent Recipes</h2>
        <a
          href="/recipes"
          class="text-sm font-medium text-terracotta hover:text-terracotta-dark transition-colors"
        >
          Browse all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {recent.map((r) => (
          <RecipeCard
            title={r.data.title}
            slug={r.data.slug}
            description={r.data.description}
            cuisine={r.data.cuisine}
            difficulty={r.data.difficulty}
            totalTime={r.data.totalTime}
            category={r.data.category}
            image={r.data.image}
          />
        ))}
      </div>
    </section>
  )}

  {/* Chef Carl — voice assistant (moved here per layout request) */}
  <section class="max-w-4xl mx-auto px-4 sm:px-6 mb-16">
    <div class="bg-warm-white rounded-2xl border border-warm-gray/10 p-8 md:p-10 flex flex-col md:flex-row items-center gap-8">
      <div class="flex-1">
        <div class="inline-flex items-center gap-2 mb-3">
          <span class="w-1.5 h-1.5 rounded-full bg-sage animate-pulse"></span>
          <span class="text-xs font-medium uppercase tracking-wide text-sage-dark">Cook Along</span>
        </div>
        <h2 class="font-display text-2xl md:text-3xl text-charcoal mb-3">Meet Chef Carl</h2>
        <p class="text-warm-gray leading-relaxed mb-5">
          A hands-free cooking companion. Ask about substitutions, start timers,
          jump to a technique, and let him drive the page while you keep your
          hands in the pan.
        </p>
        <button
          type="button"
          onclick="window.__carlWake?.()"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-sage text-warm-white font-medium hover:bg-sage-dark transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v4M8 23h8" />
          </svg>
          Talk to Chef Carl
        </button>
      </div>
      <div class="flex-shrink-0 w-full md:w-56">
        {/*
          Portrait slot — drop a 4:5 image at /public/images/chef-carl-portrait.png.
          Recommended source size 800×1000 (or larger keeping 4:5 ratio) so it
          stays crisp on retina displays. The SVG silhouette below shows when
          the image is missing.
        */}
        <div class="aspect-[4/5] rounded-xl bg-gradient-to-br from-sage-light/60 to-cream border border-warm-gray/10 relative overflow-hidden flex items-center justify-center">
          <img
            src="/images/chef-carl-portrait.png"
            alt="Chef Carl"
            class="absolute inset-0 w-full h-full object-cover"
            onerror="this.style.display='none'"
          />
          <svg class="w-20 h-20 text-sage-dark/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2">
            <circle cx="12" cy="8" r="4" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" />
          </svg>
          <span class="absolute bottom-3 left-4 text-xs text-warm-gray z-10">Standing by</span>
          <span class="absolute bottom-3 right-4 w-1.5 h-1.5 rounded-full bg-sage animate-pulse z-10"></span>
        </div>
      </div>
    </div>
  </section>

  {/* Community recipes */}
  {communitySorted.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 mb-16">
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
          <h2 class="font-display text-2xl text-charcoal">Community Creations</h2>
          <span class="px-2.5 py-0.5 rounded-full bg-sage-light text-sage-dark text-xs font-semibold uppercase tracking-wide">
            AI Generated
          </span>
        </div>
        <a
          href="/recipes?source=community"
          class="text-sm font-medium text-terracotta hover:text-terracotta-dark transition-colors"
        >
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {communitySorted.map((r) => (
          <RecipeCard
            title={r.data.title}
            slug={r.data.slug}
            description={r.data.description}
            cuisine={r.data.cuisine}
            difficulty={r.data.difficulty}
            totalTime={r.data.totalTime}
            category={r.data.category}
            image={r.data.image}
            source={r.data.source}
            hideBadge={true}
          />
        ))}
      </div>
    </section>
  )}

  {/* Generate CTA (moved here per layout request) */}
  <section class="max-w-3xl mx-auto px-4 sm:px-6 mb-16">
    <div class="bg-warm-white rounded-2xl border border-warm-gray/10 p-8 md:p-10 text-center">
      <span class="text-4xl mb-3 block">&#x2728;</span>
      <h2 class="font-display text-2xl md:text-3xl text-charcoal mb-3">Create Your Own Recipe</h2>
      <p class="text-warm-gray mb-6 max-w-lg mx-auto leading-relaxed">
        Tell us what you want to cook and our AI agents will research renowned techniques,
        ratios, and methods to build you a custom recipe.
      </p>
      <a
        href="/generate"
        class="inline-block px-6 py-3 rounded-lg bg-terracotta text-warm-white font-medium hover:bg-terracotta-dark transition-colors no-underline"
      >
        Generate a recipe &rarr;
      </a>
    </div>
  </section>

  {/* What is this */}
  <section class="bg-warm-white border-y border-warm-gray/10 py-14">
    <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
      <span class="text-4xl mb-3 block">&#x1F468;&#x200D;&#x1F373;</span>
      <h2 class="font-display text-2xl text-charcoal mb-3">What is this?</h2>
      <p class="text-warm-gray mb-5 leading-relaxed">
        Every recipe here is built from techniques, ratios, and methods sourced
        from renowned chefs and culinary traditions, then synthesized into
        something original and practical.
      </p>
      <a
        href="/about"
        class="inline-block px-5 py-2.5 rounded-lg bg-sage text-warm-white text-sm font-medium hover:bg-sage-dark transition-colors no-underline"
      >
        Learn more about the project &rarr;
      </a>
    </div>
  </section>
</Layout>
