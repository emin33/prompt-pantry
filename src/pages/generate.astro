---
import Layout from "../layouts/Layout.astro";
import RecipeGenerator from "../components/RecipeGenerator";
---

<Layout title="Generate a Recipe" description="Create a new recipe using AI-powered research.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="text-center mb-10">
      <h1 class="font-display text-3xl md:text-4xl text-charcoal mb-3">Generate a Recipe</h1>
      <p class="text-muted max-w-lg mx-auto">
        Tell us what you want to cook. Our AI pipeline will research renowned recipes and techniques, then synthesize a recipe tailored to your kitchen.
      </p>
    </div>

    <RecipeGenerator client:load />
  </section>
</Layout>
