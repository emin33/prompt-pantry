---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const techniques = await getCollection("techniques", ({ data }) => data.published);

// Group by category
const grouped = techniques.reduce(
  (acc, t) => {
    const cat = t.data.category;
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(t);
    return acc;
  },
  {} as Record<string, typeof techniques>
);

const categoryOrder = [
  "Fundamentals",
  "Heat Control",
  "Knife Skills",
  "Sauce Work",
  "Noodles",
  "Meat",
  "Baking",
];
---

<Layout title="Techniques" description="Cooking technique guides and fundamentals.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="font-display text-4xl md:text-5xl text-charcoal mb-2">Techniques</h1>
    <p class="text-warm-gray mb-4">
      The building blocks behind every recipe. Learn a technique once, use it everywhere.
    </p>
    <div class="w-24 h-0.5 bg-sage mb-10"></div>

    {categoryOrder
      .filter((cat) => grouped[cat])
      .map((cat) => (
        <section class="mb-10">
          <h2 class="font-display text-xl text-charcoal mb-4 pb-2 border-b border-warm-gray/15">
            {cat}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {grouped[cat]
              .sort((a, b) => a.data.title.localeCompare(b.data.title))
              .map((t) => (
                <a
                  href={`/techniques/${t.data.slug}`}
                  class="technique-card group block p-5 rounded-xl bg-warm-white border border-warm-gray/10 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 no-underline"
                >
                  <div>
                    <div>
                      <span class="font-medium text-charcoal group-hover:text-sage-dark transition-colors">
                        {t.data.title}
                      </span>
                      <span class="block text-sm text-warm-gray mt-1 leading-relaxed">
                        {t.data.description}
                      </span>
                      <span class="inline-block mt-2 px-2 py-0.5 rounded-full text-xs font-medium bg-golden-light text-golden">
                        {t.data.difficulty}
                      </span>
                    </div>
                  </div>
                </a>
              ))}
          </div>
        </section>
      ))}
  </div>
</Layout>

<style>
  .technique-card {
    position: relative;
    overflow: hidden;
  }

  .technique-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: #C75B3F;
    border-radius: 3px 0 0 3px;
  }
</style>
