---
import { getCollection } from "astro:content";
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import RecipeHero from "../../components/RecipeHero.astro";
import PinnableIngredients from "../../components/PinnableIngredients";
import RecipeCard from "../../components/RecipeCard.astro";
import CookMode from "../../components/CookMode";
import RecipeChat from "../../components/RecipeChat";
import RecipeVariants from "../../components/RecipeVariants.astro";

export async function getStaticPaths() {
  const recipes = await getCollection("recipes", ({ data }) => data.published);
  return recipes.map((recipe) => ({
    params: { slug: recipe.data.slug },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);
const { data } = recipe;

// Build JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  name: data.title,
  description: data.description,
  ...(data.image && { image: `https://promptpantry.org${data.image}` }),
  prepTime: `PT${data.prepTime}M`,
  cookTime: `PT${data.cookTime}M`,
  totalTime: `PT${data.totalTime}M`,
  recipeYield: `${data.servings} servings`,
  recipeCategory: data.category,
  recipeCuisine: data.cuisine,
  recipeIngredient: data.ingredients.flatMap((group) =>
    group.items.map((item) => {
      const parts = [];
      if (item.amount > 0) parts.push(String(item.amount));
      if (item.unit) parts.push(item.unit);
      parts.push(item.name);
      return parts.join(" ");
    })
  ),
  recipeInstructions: (recipe.body || "")
    .split(/^### /m)
    .filter((s) => s.trim())
    .map((block) => {
      const lines = block.trim().split("\n");
      const name = lines[0].trim();
      const text = lines.slice(1).join(" ").replace(/[*_#`]/g, "").trim();
      return { "@type": "HowToStep", name, text };
    }),
};

// Build recipe context for chat assistant
const ingredientLines = data.ingredients.flatMap((group) => [
  group.name + ":",
  ...group.items.map((item) => {
    const parts = [];
    if (item.amount > 0) parts.push(String(item.amount));
    if (item.unit) parts.push(item.unit);
    parts.push(item.name);
    return "  - " + parts.join(" ");
  }),
]).join("\n");

const recipeContext = `${data.title}

${data.description}

Cuisine: ${data.cuisine} | Difficulty: ${data.difficulty} | Servings: ${data.servings}
Prep: ${data.prepTime}m | Cook: ${data.cookTime}m | Total: ${data.totalTime}m

Ingredients:
${ingredientLines}

Full recipe content:
${recipe.body || ""}`;

// Related recipes: same cuisine or shared tags
const allRecipes = await getCollection("recipes", ({ data: d }) => d.published && d.slug !== data.slug);
const related = allRecipes
  .map((r) => ({
    recipe: r,
    score:
      (r.data.cuisine === data.cuisine ? 2 : 0) +
      r.data.tags.filter((t) => data.tags.includes(t)).length,
  }))
  .filter((r) => r.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map((r) => r.recipe);
---

<Layout title={data.title} description={data.description} ogType="article" ogImage={data.image}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    {/* Jump to Recipe */}
    <a
      href="#recipe-body"
      class="jump-to-recipe inline-flex items-center gap-1.5 mb-6 px-4 py-2 rounded-lg bg-terracotta text-white text-sm font-medium hover:bg-terracotta-dark transition-colors no-underline"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
      Jump to Recipe
    </a>

    <RecipeHero
      title={data.title}
      description={data.description}
      cuisine={data.cuisine}
      category={data.category}
      difficulty={data.difficulty}
      prepTime={data.prepTime}
      cookTime={data.cookTime}
      totalTime={data.totalTime}
      equipment={data.equipment}
      image={data.image}
      imageAspect={data.imageAspect}
    />

    <RecipeVariants variants={data.variants} variantOf={data.variantOf} />

    {/* Utility buttons */}
    <div class="no-print mb-8 flex items-center gap-4">
      <button
        onclick="window.print()"
        class="inline-flex items-center gap-1.5 text-sm text-warm-gray hover:text-charcoal transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M6 9V2h12v7M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2M6 14h12v8H6z" />
        </svg>
        Print Recipe
      </button>
      <span class="text-warm-gray/30">|</span>
      <CookMode client:load />
      <span class="text-warm-gray/30" id="chat-divider" style="display:none">|</span>
      <button
        id="show-chat-btn"
        style="display:none"
        onclick="window.__showRecipeChat?.(); this.style.display='none'; document.getElementById('chat-divider').style.display='none';"
        class="inline-flex items-center gap-1.5 text-sm text-warm-gray hover:text-charcoal transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25z" />
        </svg>
        Show Assistant
      </button>
    </div>

    <script>
      // Show the "Show Assistant" button if chat was dismissed
      if (localStorage.getItem("chatDismissed") === "true") {
        const btn = document.getElementById("show-chat-btn");
        const divider = document.getElementById("chat-divider");
        if (btn) btn.style.display = "";
        if (divider) divider.style.display = "";
      }
    </script>

    {/* Ingredients */}
    <section id="ingredients" class="mb-10 scroll-mt-20">
      <PinnableIngredients
        client:load
        servings={data.servings}
        groups={data.ingredients}
      />
    </section>

    {/* Recipe body (steps, notes, etc.) */}
    <div class="recipe-prose scroll-mt-20" id="recipe-body">
      <Content />
    </div>

    {/* Wrap steps in cards via client-side JS */}
    <script>
      function wrapSteps() {
        const prose = document.getElementById('recipe-body');
        if (!prose) return;

        const h3s = prose.querySelectorAll('h3');
        h3s.forEach((h3) => {
          const card = document.createElement('div');
          card.className = 'step-card';

          h3.parentNode?.insertBefore(card, h3);
          card.appendChild(h3);

          // Move siblings until next h3 or h2
          let next = card.nextSibling;
          while (next && !(next instanceof HTMLElement && (next.tagName === 'H3' || next.tagName === 'H2'))) {
            const toMove = next;
            next = next.nextSibling;
            card.appendChild(toMove);
          }
        });
      }
      wrapSteps();
    </script>
  </article>

  {/* Related recipes */}
  {related.length > 0 && (
    <section class="related-recipes max-w-5xl mx-auto px-4 sm:px-6 py-12 border-t border-warm-gray/15">
      <h2 class="font-display text-2xl text-charcoal mb-6">You might also like</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {related.map((r) => (
          <RecipeCard
            title={r.data.title}
            slug={r.data.slug}
            description={r.data.description}
            cuisine={r.data.cuisine}
            difficulty={r.data.difficulty}
            totalTime={r.data.totalTime}
            category={r.data.category}
            image={r.data.image}
            source={r.data.source}
          />
        ))}
      </div>
    </section>
  )}

  <RecipeChat client:idle recipeContext={recipeContext} researchUrl={data.research} />
</Layout>
