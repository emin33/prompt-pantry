---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import RecipeFilter from "../../components/RecipeFilter";

const recipes = await getCollection("recipes", ({ data }) => data.published && !data.variantOf);

const recipeData = recipes.map((r) => ({
  title: r.data.title,
  slug: r.data.slug,
  description: r.data.description,
  cuisine: r.data.cuisine,
  category: r.data.category,
  difficulty: r.data.difficulty,
  totalTime: r.data.totalTime,
  tags: r.data.tags,
  publishedDate: r.data.publishedDate,
  image: r.data.image,
  source: r.data.source,
}));
---

<Layout title="Recipes" description="Browse all recipes.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <h1 class="font-display text-4xl md:text-5xl text-charcoal mb-2">Recipes</h1>
    <p class="text-warm-gray mb-8">
      Browse all recipes.
    </p>
    <RecipeFilter client:load recipes={recipeData} />
  </div>
</Layout>
